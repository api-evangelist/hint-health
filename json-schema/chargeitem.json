{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api.hint.com/schemas/chargeitem",
  "title": "ChargeItem",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Optional if name, code and code_type are specified"
    },
    "name": {
      "type": "string",
      "description": "Required if no ID"
    },
    "code": {
      "type": "string",
      "description": "Required if no ID"
    },
    "code_type": {
      "type": "string",
      "description": "Required if no ID",
      "enum": [
        "cpt",
        "ndc",
        "loinc",
        "snowmed"
      ]
    },
    "manufacturer": {
      "type": "string"
    },
    "days_supply": {
      "type": "integer"
    }
  },
  "required": [
    "id",
    "name",
    "code",
    "code_type"
  ]
}